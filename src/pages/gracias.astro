---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@ui/Button.astro";
import { siteConfig } from "@config/site";
import { buildWhatsAppUrl, isRealWhatsAppNumber } from "@lib/whatsapp";

const title = "Gracias por tu consulta | Mercure Internacional";
const description =
  "Tu consulta fue preparada para que el equipo de Mercure Internacional pueda orientarte sobre la operación logística.";
const hasRealWhatsApp = isRealWhatsAppNumber(siteConfig.whatsappNumber);
const whatsappHref = hasRealWhatsApp
  ? buildWhatsAppUrl(
      siteConfig.whatsappNumber,
      "Hola Mercure, quiero consultar por una operación de logística internacional."
    )
  : "";
---

<BaseLayout title={title} description={description} canonical="/gracias/" noindex>
  <section class="container-page section-padding">
    <div class="max-w-3xl rounded-xl border border-line bg-white p-8 shadow-line md:p-10">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-ocean">Consulta recibida</p>
      <h1 class="mt-3 font-display text-4xl font-extrabold text-ink md:text-5xl">
        Gracias por tu consulta
      </h1>
      <p class="mt-6 text-lg leading-8 text-steel">
        Tu consulta fue preparada para que el equipo de Mercure Internacional pueda revisar
        la operación y orientarte sobre los próximos pasos.
      </p>
      <p class="mt-4 text-base leading-8 text-steel">
        Si el mensaje se abrió en WhatsApp, solo queda enviarlo desde la aplicación. Si no,
        podés volver al inicio y completar nuevamente los datos cuando lo necesites.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href="/" variant="secondary">Volver al inicio</Button>
        {
          hasRealWhatsApp && (
            <Button href={whatsappHref} target="_blank" ariaLabel="Contactar a Mercure por WhatsApp">
              Contactar por WhatsApp
            </Button>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
