---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@ui/Button.astro";
import Container from "@ui/Container.astro";
import SectionHeader from "@ui/SectionHeader.astro";
import { serviceSchema } from "@lib/schema";

const title = "Carga aérea internacional Argentina | Mercure Global";
const description =
  "Coordinación de carga aérea internacional para importaciones y cargas que requieren agilidad, análisis documental, seguimiento y entrega en Argentina.";
const pageFaq = [
  {
    question: "¿Cuándo conviene elegir transporte aéreo internacional?",
    answer:
      "Puede ser conveniente cuando la operación prioriza agilidad, cuando la carga es liviana o cuando el valor de la mercadería justifica evaluar esta modalidad."
  },
  {
    question: "¿Siempre es más rápido que la carga marítima?",
    answer:
      "Suele priorizar tiempos de tránsito, pero la conveniencia final depende de origen, disponibilidad, documentación, costos y destino."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/carga-aerea-internacional/"
  schema={serviceSchema({
    name: "Carga aérea internacional para importaciones",
    description,
    url: "/carga-aerea-internacional/"
  })}
>
  <section class="bg-white py-16 md:py-24">
    <Container>
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-ocean">Transporte aéreo internacional</p>
      <h1 class="mt-4 max-w-4xl font-display text-4xl font-extrabold leading-tight text-ink md:text-6xl">
        Carga aérea internacional para operaciones que necesitan agilidad
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-steel">
        Mercure Global coordina alternativas de logística aérea para importaciones y cargas donde el tiempo, el valor de la mercadería o la urgencia requieren un análisis especial.
      </p>
      <Button href="/#cotizar" size="lg" class="mt-8">Consultar por carga aérea internacional</Button>
    </Container>
  </section>

  <section class="section-padding bg-smoke">
    <Container>
      <SectionHeader
        eyebrow="Cuándo conviene"
        title="Agilidad con análisis operativo"
        description="La carga aérea internacional puede ser útil para productos urgentes, livianos o de mayor valor, siempre que el análisis de costos, tiempos y documentación acompañe la decisión."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        <article class="rounded-lg border border-line bg-white p-5 shadow-line"><h2 class="text-lg font-bold text-ink">Productos urgentes</h2><p class="mt-3 text-sm leading-7 text-steel">Evaluamos opciones cuando la operación requiere priorizar tiempos sin perder visibilidad del proceso.</p></article>
        <article class="rounded-lg border border-line bg-white p-5 shadow-line"><h2 class="text-lg font-bold text-ink">Costos y documentación</h2><p class="mt-3 text-sm leading-7 text-steel">Relevamos datos básicos para entender alcance, documentación disponible y condiciones logísticas.</p></article>
        <article class="rounded-lg border border-line bg-white p-5 shadow-line"><h2 class="text-lg font-bold text-ink">Seguimiento claro</h2><p class="mt-3 text-sm leading-7 text-steel">Acompañamos la coordinación y comunicación de la operación con un solo punto de contacto hasta su entrega en Argentina.</p></article>
      </div>
    </Container>
  </section>

  <section class="section-padding bg-white">
    <Container>
      <SectionHeader eyebrow="Dudas comunes" title="Preguntas sobre carga aérea internacional" />
      <div class="mt-8 grid gap-3">
        {pageFaq.map((item) => (<details class="rounded-lg border border-line bg-white p-5 shadow-line"><summary class="cursor-pointer text-base font-bold text-ink">{item.question}</summary><p class="mt-3 text-sm leading-7 text-steel">{item.answer}</p></details>))}
      </div>
      <Button href="/#cotizar" size="lg" class="mt-8">Consultar por carga aérea internacional</Button>
    </Container>
  </section>
</BaseLayout>
