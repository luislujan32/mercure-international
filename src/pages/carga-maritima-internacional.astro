---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@ui/Button.astro";
import Container from "@ui/Container.astro";
import SectionHeader from "@ui/SectionHeader.astro";
import { serviceSchema } from "@lib/schema";

const title = "Carga marítima internacional Argentina | Mercure Global";
const description =
  "Coordinación de carga marítima internacional para importaciones, contenedores, pallets, carga consolidada y proyectos con seguimiento hacia Argentina.";
const pageFaq = [
  {
    question: "¿Qué significa FCL y LCL?",
    answer:
      "FCL se usa cuando la operación trabaja con un contenedor completo. LCL se usa cuando la carga comparte espacio con otras operaciones, también conocida como carga consolidada."
  },
  {
    question: "¿La carga marítima sirve para cualquier producto?",
    answer:
      "Depende del producto, volumen, embalaje, origen, documentación y necesidades de entrega. Por eso analizamos cada operación antes de recomendar una modalidad."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/carga-maritima-internacional/"
  schema={serviceSchema({
    name: "Carga marítima internacional para importaciones",
    description,
    url: "/carga-maritima-internacional/"
  })}
>
  <section class="bg-white py-16 md:py-24">
    <Container>
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-ocean">Transporte marítimo internacional</p>
      <h1 class="mt-4 max-w-4xl font-display text-4xl font-extrabold leading-tight text-ink md:text-6xl">
        Carga marítima internacional para importar con mayor capacidad
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-steel">
        Mercure Global centraliza la coordinación de operaciones marítimas para cargas grandes, pallets, contenedores o esquemas consolidados hacia Argentina.
      </p>
      <Button href="/#cotizar" size="lg" class="mt-8">Consultar por carga marítima internacional</Button>
    </Container>
  </section>

  <section class="section-padding bg-smoke">
    <Container>
      <SectionHeader
        eyebrow="Capacidad y planificación"
        title="Una modalidad para operaciones planificadas"
        description="La importación marítima suele ser adecuada para cargas de mayor volumen o para operaciones donde la planificación permite evaluar costos, documentación y coordinación con más anticipación."
      />
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        <article class="rounded-lg border border-line bg-white p-5 shadow-line">
          <h2 class="text-lg font-bold text-ink">FCL</h2>
          <p class="mt-3 text-sm leading-7 text-steel">Contenedor completo para operaciones con volumen suficiente o necesidades específicas de coordinación.</p>
        </article>
        <article class="rounded-lg border border-line bg-white p-5 shadow-line">
          <h2 class="text-lg font-bold text-ink">LCL</h2>
          <p class="mt-3 text-sm leading-7 text-steel">Carga consolidada marítima para operaciones que no requieren ocupar un contenedor completo.</p>
        </article>
        <article class="rounded-lg border border-line bg-white p-5 shadow-line">
          <h2 class="text-lg font-bold text-ink">Seguimiento</h2>
          <p class="mt-3 text-sm leading-7 text-steel">Acompañamos documentación, coordinación internacional, arribo y entrega final según el alcance definido para la operación.</p>
        </article>
      </div>
    </Container>
  </section>

  <section class="section-padding bg-white">
    <Container>
      <SectionHeader eyebrow="Dudas comunes" title="Preguntas sobre carga marítima internacional" />
      <div class="mt-8 grid gap-3">
        {pageFaq.map((item) => (
          <details class="rounded-lg border border-line bg-white p-5 shadow-line">
            <summary class="cursor-pointer text-base font-bold text-ink">{item.question}</summary>
            <p class="mt-3 text-sm leading-7 text-steel">{item.answer}</p>
          </details>
        ))}
      </div>
      <Button href="/#cotizar" size="lg" class="mt-8">Consultar por carga marítima internacional</Button>
    </Container>
  </section>
</BaseLayout>
