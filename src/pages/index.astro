---
import BaseLayout from "@layouts/BaseLayout.astro";
import Benefits from "@sections/Benefits.astro";
import FAQ from "@sections/FAQ.astro";
import FinalCTA from "@sections/FinalCTA.astro";
import Hero from "@sections/Hero.astro";
import MainSolutions from "@sections/MainSolutions.astro";
import Process from "@sections/Process.astro";
import Routes from "@sections/Routes.astro";
import Services from "@sections/Services.astro";
import StrategicLocation from "@sections/StrategicLocation.astro";
import TargetAudience from "@sections/TargetAudience.astro";
import TrustStats from "@sections/TrustStats.astro";
import { faqItems } from "@data/faq";
import { faqPageSchema, organizationSchema, serviceSchema, websiteSchema } from "@lib/schema";

type JsonLd = Record<string, unknown>;

const title = "Mercure Global | Importaciones y proyectos logísticos desde el NOA";
const description =
  "Gestión integral para importaciones, freight forwarding y proyectos logísticos internacionales o regionales desde Jujuy y el NOA, con un solo punto de contacto.";

const schemas = [
  organizationSchema(),
  websiteSchema(),
  serviceSchema({
    name: "Importaciones y proyectos logísticos con gestión integral",
    description,
    url: "/"
  }),
  faqPageSchema(faqItems)
].filter((schema): schema is JsonLd => Boolean(schema));
---

<BaseLayout
  title={title}
  description={description}
  canonical="/"
  schema={schemas}
>
  <Hero />
  <TrustStats />
  <MainSolutions />
  <Services />
  <Process />
  <StrategicLocation />
  <Benefits />
  <TargetAudience />
  <Routes />
  <FAQ />
  <FinalCTA />
</BaseLayout>
