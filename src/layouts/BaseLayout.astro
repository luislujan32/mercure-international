---
import "@assets/styles/global.css";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import WhatsAppButton from "@components/layout/WhatsAppButton.astro";
import { buildSeoMeta, type SeoType } from "@lib/seo";
import { jsonLdScript } from "@lib/schema";
import { siteConfig } from "@config/site";

type JsonLd = Record<string, unknown>;

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  type?: SeoType;
  schema?: JsonLd | JsonLd[];
};

const { title, description, canonical, ogImage, noindex, type, schema } = Astro.props;
const seo = buildSeoMeta({ title, description, canonical, ogImage, noindex, type });
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />

    {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={seo.type} />
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.ogTitle} />
    <meta name="twitter:description" content={seo.ogDescription} />
    <meta name="twitter:image" content={seo.ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    {
      schema && (
        <script is:inline type="application/ld+json" set:html={jsonLdScript(schema)} />
      )
    }
  </head>
  <body>
    <a
      href="#main-content"
      class="fixed left-4 top-4 z-50 -translate-y-24 rounded-md bg-marine px-4 py-3 text-sm font-semibold text-white shadow-premium transition focus:translate-y-0"
    >
      Saltar al contenido principal
    </a>

    <Header />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <Footer />
    <WhatsAppButton />
  </body>
</html>
