---
import { siteConfig } from "@config/site";
import Container from "@ui/Container.astro";

const year = new Date().getFullYear();
const isPlaceholder = (value: string) => /a definir|x{4,}/i.test(value);
const contactItems = [
  { label: "Teléfono", value: siteConfig.phone },
  { label: "Email", value: siteConfig.email }
].filter((item) => item.value && !isPlaceholder(item.value));
const hasContactItems = contactItems.length > 0;
const footerGridClass = hasContactItems
  ? "grid gap-10 py-12 md:grid-cols-[1.2fr_0.8fr_0.8fr] md:py-16"
  : "grid gap-10 py-12 md:grid-cols-[1.2fr_0.8fr] md:py-16";
---

<footer class="border-t border-white/10 bg-marine text-white">
  <Container class={footerGridClass}>
    <div>
      <img src={siteConfig.logo} alt={siteConfig.name} class="h-24 w-auto rounded-md object-contain" loading="lazy" />
      <p class="mt-4 font-display text-xl font-extrabold text-white">{siteConfig.name}</p>
      <p class="mt-1 text-sm font-semibold text-cyan">{siteConfig.brandClaim}</p>
      <p class="mt-4 max-w-md text-sm leading-7 text-mist">{siteConfig.description}</p>
      <p class="mt-5 text-sm leading-7 text-mist">
        Mercure Global es la marca de soluciones logísticas internacionales de {siteConfig.companyName}.
      </p>
    </div>

    <nav aria-label="Navegación de pie de página">
      <p class="text-sm font-bold uppercase tracking-[0.12em] text-gold">Servicios</p>
      <ul class="mt-4 grid gap-3">
        {
          siteConfig.footerNavigation.map((item) => (
            <li>
              <a class="text-sm font-medium text-mist transition hover:text-cyan" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    {
      hasContactItems && (
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.12em] text-gold">Contacto</p>
          <ul class="mt-4 grid gap-3">
            {contactItems.map((item) => (
              <li class="text-sm text-mist">
                <span class="font-semibold text-white">{item.label}:</span> {item.value}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </Container>

  <div class="border-t border-white/10 py-5">
    <Container class="text-sm text-mist">
      {`© ${year} ${siteConfig.companyName}. Todos los derechos reservados.`}
    </Container>
  </div>
</footer>
