---
import { siteConfig } from "@config/site";
import { buildWhatsAppUrl, isRealWhatsAppNumber } from "@lib/whatsapp";

const message =
  "Hola Mercure, quiero recibir asesoramiento para una operación de logística internacional.";
const shouldRender = isRealWhatsAppNumber(siteConfig.whatsappNumber);
const href = shouldRender ? buildWhatsAppUrl(siteConfig.whatsappNumber, message) : "";
---

{
  shouldRender && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp a Mercure Global"
      class="fixed bottom-5 right-5 z-50 inline-flex size-14 items-center justify-center rounded-full bg-success text-white shadow-premium transition hover:scale-105 hover:bg-[#12805f] focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-3 focus-visible:outline-signal"
    >
      <span aria-hidden="true" class="text-xl font-black">W</span>
    </a>
  )
}
