---
import { siteConfig } from "@config/site";
import Button from "@ui/Button.astro";
import Container from "@ui/Container.astro";
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-marine/92 text-white backdrop-blur-xl">
  <Container class="flex min-h-20 items-center justify-between gap-5">
    <a href="/" class="flex items-center gap-3 font-display" aria-label="Ir al inicio">
      <img
        src={siteConfig.logo}
        alt={siteConfig.name}
        class="h-11 w-14 rounded-md border border-cyan/35 bg-white/8 object-contain p-1 shadow-soft"
        loading="eager"
      />
      <span class="grid leading-none">
        <span class="text-lg font-extrabold text-white">{siteConfig.name}</span>
        <span class="mt-1 text-[0.68rem] font-bold uppercase text-mist">{siteConfig.brandClaim}</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Navegación principal">
      {
        siteConfig.mainNavigation.map((item) => (
          <a class="text-sm font-semibold text-mist transition hover:text-cyan" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <Button href="/#cotizar" size="sm">Solicitar asesoramiento</Button>
    </div>

    <details class="group relative md:hidden">
      <summary class="flex min-h-11 cursor-pointer list-none items-center rounded-md border border-white/15 bg-white/8 px-4 text-sm font-semibold text-white shadow-line marker:hidden">
        Menú
      </summary>
      <div class="absolute right-0 top-14 w-72 rounded-lg border border-white/10 bg-harbor p-3 shadow-premium">
        <nav class="grid gap-1" aria-label="Navegación principal móvil">
          {
            siteConfig.mainNavigation.map((item) => (
              <a class="rounded-md px-3 py-2.5 text-sm font-semibold text-mist transition hover:bg-white/10 hover:text-cyan" href={item.href}>
                {item.label}
              </a>
            ))
          }
          <Button href="/#cotizar" size="sm" class="mt-2 w-full">Solicitar asesoramiento</Button>
        </nav>
      </div>
    </details>
  </Container>
</header>
