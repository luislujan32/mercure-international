---
import Container from "@ui/Container.astro";
import SectionHeader from "@ui/SectionHeader.astro";
import { faqItems } from "@data/faq";
---

<section id="preguntas-frecuentes" class="section-padding bg-smoke">
  <Container>
    <SectionHeader
      eyebrow="FAQ"
      title="Preguntas frecuentes sobre importación y logística internacional"
      description="Respuestas claras para empezar a evaluar tu operación con más contexto."
      align="center"
    />
    <div class="mx-auto mt-10 grid max-w-4xl gap-3">
      {
        faqItems.map((item) => (
          <details class="group rounded-lg border border-line bg-white p-5 shadow-line">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-left text-base font-bold text-ink marker:hidden">
              <span>{item.question}</span>
              <span class="mt-1 text-xl leading-none text-ocean transition group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-4 text-sm leading-7 text-steel">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </Container>
</section>
