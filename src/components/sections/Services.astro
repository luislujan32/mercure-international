---
import Container from "@ui/Container.astro";
import SectionHeader from "@ui/SectionHeader.astro";
import { services } from "@data/services";
---

<section id="servicios" class="section-padding bg-white">
  <Container>
    <SectionHeader
      eyebrow="Servicios"
      title="Soluciones para coordinar tu importación de punta a punta"
      description="Desde el análisis inicial hasta la entrega final, coordinamos alternativas logísticas según origen, urgencia, volumen y destino."
    />
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <article class="rounded-lg border border-line bg-white p-5 shadow-line transition hover:-translate-y-1 hover:shadow-soft">
            <div class="flex size-11 items-center justify-center rounded-md bg-mist text-xs font-black uppercase text-marine">
              {service.icon?.slice(0, 2) ?? "MI"}
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink">{service.title}</h3>
            <p class="mt-3 text-sm leading-7 text-steel">{service.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
