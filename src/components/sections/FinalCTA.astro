---
import Container from "@ui/Container.astro";
import QuoteForm from "@sections/QuoteForm";
import { siteConfig } from "@config/site";
import { isRealWhatsAppNumber } from "@lib/whatsapp";

const formWhatsAppNumber = isRealWhatsAppNumber(siteConfig.whatsappNumber)
  ? siteConfig.whatsappNumber
  : "";
---

<section id="cotizar" class="section-padding bg-white">
  <Container>
    <div class="relative overflow-hidden rounded-xl bg-marine p-6 text-white shadow-premium md:p-10 lg:p-12">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_85%_8%,rgba(16,215,255,0.18),transparent_22rem),linear-gradient(135deg,#031225,#04162f)]"></div>
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div class="relative">
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-gold">Pre-cotización global</p>
          <h2 class="mt-3 max-w-2xl font-display text-3xl font-extrabold md:text-5xl">
            Contanos qué necesitás cotizar con Mercure Global
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-mist">
            Compartinos si necesitás importar un producto o coordinar un proyecto logístico.
            El equipo Mercure podrá orientar la consulta y ordenar los próximos pasos.
          </p>
          <p class="mt-5 max-w-xl border-l-4 border-signal pl-4 text-sm leading-7 text-mist">
            No hace falta tener todos los datos cerrados. Podemos empezar por analizar el
            producto o carga, el origen, el destino, la urgencia y las necesidades operativas.
          </p>
        </div>
        <div class="relative">
          <QuoteForm client:visible whatsappNumber={formWhatsAppNumber} />
        </div>
      </div>
    </div>
  </Container>
</section>
