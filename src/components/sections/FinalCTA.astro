---
import Button from "@ui/Button.astro";
import Container from "@ui/Container.astro";
---

<section id="cotizar" class="section-padding bg-white">
  <Container>
    <div class="rounded-xl bg-marine p-8 text-white shadow-premium md:p-12">
      <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-gold">Pre-cotización</p>
          <h2 class="mt-3 max-w-2xl font-display text-3xl font-extrabold md:text-5xl">
            Contanos qué querés importar
          </h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-mist">
            Compartinos los datos principales de tu operación y te orientamos sobre los
            próximos pasos para coordinar la logística internacional.
          </p>
        </div>
        <Button href="#cotizar" variant="secondary" size="lg" class="bg-white">
          Solicitar asesoramiento
        </Button>
      </div>
    </div>
  </Container>
</section>
