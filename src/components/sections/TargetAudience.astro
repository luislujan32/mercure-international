---
import Container from "@ui/Container.astro";
import SectionHeader from "@ui/SectionHeader.astro";
import { targetAudience } from "@data/targetAudience";
---

<section class="section-padding bg-marine text-white">
  <Container>
    <SectionHeader
      eyebrow="Para quiénes"
      title="Pensado para empresas que quieren importar mejor"
      description="Si necesitás traer mercadería, insumos, repuestos o maquinaria, podemos ayudarte a ordenar la operación antes de avanzar."
      class="[&_*]:text-white [&_p]:text-mist"
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        targetAudience.map((audience) => (
          <article class="rounded-lg border border-cyan/15 bg-white/10 p-5">
            <h3 class="text-lg font-bold text-white">{audience.title}</h3>
            <p class="mt-3 text-sm leading-7 text-mist">{audience.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
