---
import Container from "@ui/Container.astro";
import SectionHeader from "@ui/SectionHeader.astro";
import { benefits } from "@data/benefits";
---

<section class="section-padding bg-white">
  <Container>
    <SectionHeader
      eyebrow="Beneficios"
      title="Más previsibilidad para decidir y avanzar"
      description="Trabajamos para reducir incertidumbre, mejorar la trazabilidad y sostener una comunicación clara durante toda la operación."
      align="center"
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        benefits.map((benefit) => (
          <article class="rounded-lg border border-line bg-smoke p-5">
            <span class="block h-1 w-12 rounded-full bg-gradient-to-r from-cyan to-signal"></span>
            <h3 class="mt-5 text-lg font-bold text-ink">{benefit.title}</h3>
            <p class="mt-3 text-sm leading-7 text-steel">{benefit.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
