---
import { Icon } from "astro-icon/components";
import Button from "@ui/Button.astro";
import Container from "@ui/Container.astro";

const operationSteps = [
  { label: "Origen internacional", icon: "lucide:globe" },
  { label: "Documentación", icon: "lucide:file-check-2" },
  { label: "Carga en tránsito", icon: "lucide:container" },
  { label: "Arribo a Argentina", icon: "lucide:map-pin-check" },
  { label: "Entrega final", icon: "lucide:truck" }
];
---

<section class="relative overflow-hidden border-b border-line bg-white">
  <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-mist to-transparent"></div>
  <Container class="relative grid gap-12 py-16 md:grid-cols-[1.05fr_0.95fr] md:items-center md:py-24">
    <div>
      <p class="inline-flex rounded-full border border-line bg-white px-4 py-2 text-sm font-semibold text-ocean shadow-line">
        Logística internacional para empresas
      </p>
      <h1 class="mt-6 max-w-4xl font-display text-4xl font-extrabold leading-tight text-ink md:text-6xl">
        Importá productos desde cualquier parte del mundo con respaldo logístico
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-steel">
        Te acompañamos con asesoramiento, coordinación internacional, seguimiento claro y
        entrega en Argentina para que tu operación avance con más previsibilidad.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href="#cotizar" size="lg">Solicitar asesoramiento</Button>
        <Button href="#proceso" variant="secondary" size="lg">Ver cómo funciona</Button>
      </div>
      <p class="mt-8 max-w-xl border-l-4 border-signal pl-4 text-sm leading-7 text-graphite">
        Asesoramiento de punta a punta para reducir incertidumbre antes, durante y después
        de la operación.
      </p>
    </div>

    <div class="rounded-xl border border-line bg-smoke p-4 shadow-premium md:p-6" aria-label="Resumen visual del proceso logístico">
      <div class="relative overflow-hidden rounded-lg bg-marine p-5 text-white">
        <div class="absolute right-5 top-5 flex size-11 items-center justify-center rounded-md bg-white/10 text-gold">
          <Icon name="lucide:route" class="size-6" aria-hidden="true" />
        </div>
        <p class="text-sm font-semibold text-gold">Operación internacional</p>
        <p class="mt-2 max-w-xs font-display text-2xl font-extrabold">Coordinación punta a punta</p>
        <div class="mt-5 grid grid-cols-3 gap-2 text-xs font-semibold text-mist">
          <span class="rounded-md bg-white/10 px-3 py-2">Origen</span>
          <span class="rounded-md bg-white/10 px-3 py-2">Tránsito</span>
          <span class="rounded-md bg-white/10 px-3 py-2">Destino</span>
        </div>
      </div>
      <div class="mt-4 grid gap-3">
        {
          operationSteps.map((step, index) => (
            <div class="flex items-center gap-4 rounded-lg border border-line bg-white p-4 shadow-line">
              <span class="flex size-10 shrink-0 items-center justify-center rounded-md bg-mist text-marine">
                <Icon name={step.icon} class="size-5" aria-hidden="true" />
              </span>
              <span class="text-sm font-semibold text-graphite">{step.label}</span>
              <span class="ml-auto flex items-center gap-2" aria-hidden="true">
                <span class="hidden h-px w-10 bg-line sm:block"></span>
                <span class="flex size-7 items-center justify-center rounded-full bg-marine text-xs font-extrabold text-white">
                  {index + 1}
                </span>
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
