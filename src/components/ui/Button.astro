---
type Props = {
  href?: string;
  variant?: "primary" | "secondary" | "inverse" | "ghost";
  size?: "sm" | "md" | "lg";
  class?: string;
  target?: string;
  ariaLabel?: string;
};

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  target,
  ariaLabel
} = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center rounded-md font-semibold transition focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-3 focus-visible:outline-cyan disabled:pointer-events-none disabled:opacity-60";

const variantClasses = {
  primary: "bg-cyan text-marine shadow-soft hover:bg-aqua",
  secondary: "border border-cyan/35 bg-white/95 text-marine shadow-line hover:border-cyan hover:bg-mist",
  inverse: "border border-white/25 bg-white/10 text-white shadow-line hover:bg-white/15",
  ghost: "text-marine hover:bg-mist"
};

const sizeClasses = {
  sm: "min-h-10 px-4 py-2 text-sm",
  md: "min-h-11 px-5 py-3 text-sm",
  lg: "min-h-12 px-6 py-3.5 text-base"
};

const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className];
const rel = target === "_blank" ? "noopener noreferrer" : undefined;
---

{
  href ? (
    <a href={href} target={target} rel={rel} aria-label={ariaLabel} class:list={classes}>
      <slot />
    </a>
  ) : (
    <button type="button" aria-label={ariaLabel} class:list={classes}>
      <slot />
    </button>
  )
}
